"rules.goal.title" = "The Goal";
"rules.goal.body" = "Slide the large 2×2 block — Cao Cao — down to the exit gap at the bottom of the board. This is the classic Chinese sliding-block puzzle Huarong Dao (华容道), based on the escape of the warlord Cao Cao after the Battle of Red Cliffs in Romance of the Three Kingdoms.";
"rules.moves.title" = "How to Move";
"rules.moves.body" = "Tap any block to select it, then swipe in the direction you want to slide it. A block can only move into empty space — no jumping, no rotating.";
"rules.hint.title" = "Stuck?";
"rules.hint.body" = "Tap Hint for the next correct move toward a solution. The classic puzzle takes real thought to solve — some solutions need 80+ moves.";

